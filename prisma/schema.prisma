// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
}

model User {
  id                    String    @id @default(auto()) @map("_id") @db.ObjectId
  name                  String
  email                 String    @unique
  password              String
  isAdmin               Boolean   @default(false)
  resetPasswordOTP      String?
  resetPasswordExpires  DateTime?
  googleId              String?
  phoneNumber           String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  wishlistItems         UserWishlist[]
  addresses             Address[]
  orders                Order[]
  reviews               Review[]
}

model Product {
  id                String      @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  description       String      @default("No description provided.")
  basePrice         Float
  sku               String?     @unique
  images            String[]
  maskImage         String?
  category          String
  stock             Int         @default(0)
  lowStockThreshold Int         @default(5)
  salesCount        Int         @default(0)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  wishlistItems     UserWishlist[]
  orderItems        OrderItem[]
  reviews           Review[]
}

model Order {
  id                String      @id @default(auto()) @map("_id") @db.ObjectId
  user              User?       @relation(fields: [userId], references: [id])
  userId            String?     @db.ObjectId
  customerName      String
  email             String
  phone             String?
  shippingAddress   Json
  billingAddress    Json?
  paymentMethod     String
  paymentResult     Json?
  totalPrice        Float       @default(0.0)
  discountAmount    Float       @default(0.0)
  couponCode        String?
  isPaid            Boolean     @default(false)
  paidAt            DateTime?
  isDelivered       Boolean     @default(false)
  deliveredAt       DateTime?
  trackingNumber    String?
  trackingURL       String?
  estimatedDelivery DateTime?
  status            String      @default("pending")
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  orderItems        OrderItem[]
  returns           ReturnRequest[]
  @@index([email])
  @@index([status])
}

model OrderItem {
  id              String  @id @default(auto()) @map("_id") @db.ObjectId
  order           Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId         String  @db.ObjectId
  product         Product? @relation(fields: [productId], references: [id])
  productId       String? @db.ObjectId
  name            String
  quantity        Int     @default(1)
  price           Float
  customization   Json?
}

model Review {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])
  userId      String   @db.ObjectId
  userName    String
  product     Product? @relation(fields: [productId], references: [id])
  productId   String?  @db.ObjectId
  pageName    String?
  rating      Int
  comment     String
  helpfulBy   Json?    @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UserWishlist {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String   @db.ObjectId
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String   @db.ObjectId
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model Settings {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  siteName      String   @default("Vitthal Photo Frames")
  logoUrl       String   @default("/assets/images/logo.png")
  contactEmail  String   @default("vitthalphotos99@gmail.com")
  contactPhone  String   @default("+91 9876543210")
  address       String   @default("Pandharpur, Maharashtra, India")
  socialLinks   Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Address {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String   @db.ObjectId
  name        String
  phone       String
  address     String
  city        String
  state       String
  postalCode  String
  country     String  @default("India")
  isDefault   Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([userId])
}

model Coupon {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  code            String   @unique
  description     String?
  discountType    String   @default("percentage")
  discountValue   Float
  maxDiscount     Float?
  minOrderValue   Float?
  maxUses         Int?
  currentUses     Int      @default(0)
  isActive        Boolean  @default(true)
  startsAt        DateTime
  expiresAt       DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@index([isActive])
}

model ReturnRequest {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId     String   @db.ObjectId
  reason      String
  description String?
  status      String   @default("pending")
  refundAmount Float?
  refundStatus String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([orderId])
  @@index([status])
}

model ContactForm {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  status    String   @default("new")
  response  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([status])
}

model NewsletterSubscriber {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([isActive])
}
