# ============================================
# CRITICAL SECURITY CONFIGURATION
# ============================================

# Must be set! Generate strong random string
JWT_SECRET=your_strong_random_jwt_secret_here_min_32_chars

# Database
MONGO_URI=your_mongodb_connection_string
DATABASE_URL=your_mongodb_connection_string

# Only add your domain(s) - NEVER allow all origins
ALLOWED_ORIGINS=https://vitthalphotos.com,https://www.vitthalphotos.com

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_BUCKET_NAME=your_s3_bucket_name
AWS_REGION=ap-south-1

# Razorpay Payment Keys
RAZORPAY_KEY_ID=your_razorpay_key
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Email Service
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password

# SMS Service (Twilio or similar)
SMS_API_KEY=your_sms_api_key
SMS_FROM=+91XXXXXXXXXX

# Rate Limiting (optional overrides)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Node environment
NODE_ENV=production

# Server port
PORT=5000

# Log level
LOG_LEVEL=error

# Session timeout (minutes)
SESSION_TIMEOUT=30

# Password reset token expiry (minutes)
PASSWORD_RESET_EXPIRY=15
